# ============================================================================
# RESTAURANT PLATFORM — Environment Variables Reference
# ============================================================================
# 
# This file is DOCUMENTATION only.
# Actual values live in Doppler — see docs/deploy.md.
#
# Local dev: `doppler run -- pnpm dev`
# No .env.local file is created or needed.
#
# ============================================================================

# --- Database (Neon Postgres) ---
# Connection string from Neon dashboard → branch → connection details
# Use the POOLED connection (-pooler suffix in hostname)
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require"

# --- Better-Auth ---
# Generate fresh per environment: openssl rand -base64 32
# DO NOT reuse across environments
BETTER_AUTH_SECRET=""

# The full URL of the platform app for this environment
# dev: http://localhost:3000
# stg: https://admin.staging.deliverse.app
# prd: https://admin.deliverse.app
BETTER_AUTH_URL=""

# --- OAuth: Google ---
# https://console.cloud.google.com/apis/credentials
# Register redirect URIs:
#   dev: http://localhost:3000/api/auth/callback/google
#   stg: https://admin.staging.deliverse.app/api/auth/callback/google
#   prd: https://admin.deliverse.app/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Email (Resend) ---
# https://resend.com/api-keys
# Use test key (re_xxx) for dev/stg, production key for prd
# RESEND_FROM_EMAIL must be from a verified domain in prd
RESEND_API_KEY=""
RESEND_FROM_EMAIL="onboarding@resend.dev"

# --- App URLs ---
# Public-facing URLs (exposed to client bundle)
# dev: NEXT_PUBLIC_PLATFORM_URL=http://localhost:3000
#      NEXT_PUBLIC_STOREFRONT_BASE_DOMAIN=localhost:3001
# stg: NEXT_PUBLIC_PLATFORM_URL=https://admin.staging.deliverse.app
#      NEXT_PUBLIC_STOREFRONT_BASE_DOMAIN=staging.deliverse.app
# prd: NEXT_PUBLIC_PLATFORM_URL=https://admin.deliverse.app
#      NEXT_PUBLIC_STOREFRONT_BASE_DOMAIN=deliverse.app
NEXT_PUBLIC_PLATFORM_URL=""
NEXT_PUBLIC_STOREFRONT_BASE_DOMAIN=""

# --- Inngest (async jobs) ---
# https://inngest.com — sign up, create env per stage
# Optional in dev (events log to console if missing)
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# --- Payments (Stripe Connect) ---
# https://dashboard.stripe.com/apikeys — use test keys (sk_test_…) in dev/stg.
# STRIPE_WEBHOOK_SECRET (whsec_…) comes from the webhook endpoint you register at
# https://dashboard.stripe.com/webhooks — the endpoint MUST be Connect-enabled
# ("Listen to events on Connected accounts") so account.updated is delivered.
# Local: `stripe listen --forward-connect-to localhost:3000/api/webhooks/stripe`
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Publishable key (pk_test_… / pk_live_…) — exposed to the storefront client
# bundle for Stripe.js / Payment Element (DEL-44).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- Observability ---
# Sentry: https://sentry.io
# Optional in dev
SENTRY_DSN=""

# PostHog: https://posthog.com  
# Optional in dev
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
